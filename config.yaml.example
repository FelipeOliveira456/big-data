# Copy to config.yaml and adjust paths.

graph_raw_path: data/raw/soc-pokec-relationships.txt
dataset_slug: pokec
reports_dir: reports
seed: 42
lpa_max_iter: 50

# null = auto from CPU count (override with LPA_WORKERS or LPA_CHUNK_DIVISOR)
lpa_chunk_divisor: null

# null = same as lpa_chunk_divisor on single-host runs
ray_num_cpus: null
dask_n_workers: null

# Leave null for local Ray/Dask on one machine (default).
ray_head_address: null
dask_scheduler_address: null
